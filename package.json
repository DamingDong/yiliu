{
  "name": "yiliu",
  "version": "2.0.0",
  "description": "忆流 - 随时捕捉、自动整理、按需浮现的 AI 笔记知识库",
  "main": "dist-electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.backend.json && tsc -p tsconfig.electron.json && vite build && electron-builder",
    "build:vite": "vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently \"vite\" \"electron .\"",
    "test": "vitest run"
  },
  "dependencies": {
    "@libsql/client": "^0.14.0",
    "@llm-tools/embedjs-libsql": "^0.1.31",
    "@xenova/transformers": "^2.17.0",
    "openai": "^4.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^8.2.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0",
    "typescript": "^5.3.3",
    "vite": "^5.0.0",
    "vitest": "^4.1.0"
  },
  "build": {
    "appId": "com.yiliu.app",
    "productName": "忆流",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "mac": {
      "target": "dmg",
      "icon": "public/icon.png"
    },
    "win": {
      "target": "exe"
    },
    "asar": true
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
