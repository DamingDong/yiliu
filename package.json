{
  "name": "yiliu",
  "version": "2.1.0",
  "description": "忆流 - 随时捕捉、自动整理、按需浮现的 AI 笔记知识库",
  "author": "忆流团队",
  "main": "dist-electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.backend.json && tsc -p tsconfig.electron.json && tsc -p tsconfig.preload.json && vite build && electron-builder",
    "build:vite": "vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently \"vite\" \"electron .\"",
    "test": "vitest run"
  },
  "dependencies": {
    "@libsql/client": "^0.14.0",
    "@llm-tools/embedjs-libsql": "^0.1.31",
    "@xenova/transformers": "^2.17.0",
    "openai": "^4.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20.0.0",
    "@types/prop-types": "^15.7.15",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^8.2.0",
    "electron": "^34.0.0",
    "electron-builder": "^24.13.3",
    "happy-dom": "^20.8.9",
    "jsdom": "^29.0.1",
    "typescript": "^5.3.3",
    "vite": "^5.0.0",
    "vitest": "1.6.0"
  },
  "build": {
    "appId": "com.yiliu.app",
    "productName": "忆流",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "mac": {
      "target": "dmg",
      "icon": "public/icon.png",
      "category": "public.app-category.productivity"
    },
    "win": {
      "target": "exe"
    },
    "asar": true,
    "extraMetadata": {
      "main": "dist-electron/main.js"
    }
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
